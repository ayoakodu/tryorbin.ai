# Base44 App Configuration
# Copy this file to .env and fill in the values from your Base44 dashboard

VITE_BASE44_APP_ID=your_app_id_here
VITE_BASE44_FUNCTIONS_VERSION=your_functions_version_here
VITE_BASE44_APP_BASE_URL=https://your-app.base44.com

# Anthropic Claude API — powers the AI Write button in the email editor
# Get your key at https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=sk-ant-...
# Also set this for the Vercel serverless function fallback:
ANTHROPIC_API_KEY=sk-ant-...
